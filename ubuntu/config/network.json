{
  "network_services": {
    "ipv6": {
      "status": "enabled",
      "disable_sysctl_keys": [
        "net.ipv6.conf.all.disable_ipv6",
        "net.ipv6.conf.default.disable_ipv6"
      ]
    },
    "wireless": {
      "restrict": true
    },
    "bluetooth": {
      "package": "bluez",
      "service": "bluetooth.service",
      "restrict": true
    }
  },
  "kernel_modules": [
    { "name": "dccp", "type": "net", "restrict": true },
    { "name": "tipc", "type": "net", "restrict": true },
    { "name": "rds",  "type": "net", "restrict": true },
    { "name": "sctp", "type": "net", "restrict": true }
  ],
  "network_parameters": {
    "sysctl_conf_file": "/etc/sysctl.d/60-netipv4_sysctl.conf",
    "sysctl_conf_file_ipv6": "/etc/sysctl.d/60-netipv6_sysctl.conf",
    "ipv4": [
      { "name": "net.ipv4.ip_forward", "value": "0", "flush": "net.ipv4.route.flush", "check": "ip_forwarding" },
      { "name": "net.ipv6.conf.all.forwarding", "value": "0", "flush": "net.ipv6.route.flush", "check": "ip_forwarding" },
      { "name": "net.ipv4.conf.all.send_redirects", "value": "0", "flush": "net.ipv4.route.flush", "check": "packet_redirect" },
      { "name": "net.ipv4.conf.default.send_redirects", "value": "0", "flush": "net.ipv4.route.flush", "check": "packet_redirect" },
      { "name": "net.ipv4.icmp_ignore_bogus_error_responses", "value": "1", "flush": "net.ipv4.route.flush", "check": "bogus_icmp" },
      { "name": "net.ipv4.icmp_echo_ignore_broadcasts", "value": "1", "flush": "net.ipv4.route.flush", "check": "broadcast_icmp" },
      { "name": "net.ipv4.conf.all.accept_redirects", "value": "0", "flush": "net.ipv4.route.flush", "check": "icmp_redirects" },
      { "name": "net.ipv4.conf.default.accept_redirects", "value": "0", "flush": "net.ipv4.route.flush", "check": "icmp_redirects" },
      { "name": "net.ipv4.conf.all.secure_redirects", "value": "0", "flush": "net.ipv4.route.flush", "check": "secure_redirects" },
      { "name": "net.ipv4.conf.default.secure_redirects", "value": "0", "flush": "net.ipv4.route.flush", "check": "secure_redirects" },
      { "name": "net.ipv4.conf.all.rp_filter", "value": "1", "flush": "net.ipv4.route.flush", "check": "reverse_path_filter" },
      { "name": "net.ipv4.conf.default.rp_filter", "value": "1", "flush": "net.ipv4.route.flush", "check": "reverse_path_filter" },
      { "name": "net.ipv4.conf.all.accept_source_route", "value": "0", "flush": "net.ipv4.route.flush", "check": "source_route" },
      { "name": "net.ipv4.conf.default.accept_source_route", "value": "0", "flush": "net.ipv4.route.flush", "check": "source_route" },
      { "name": "net.ipv4.conf.all.log_martians", "value": "1", "flush": "net.ipv4.route.flush", "check": "log_martians" },
      { "name": "net.ipv4.conf.default.log_martians", "value": "1", "flush": "net.ipv4.route.flush", "check": "log_martians" },
      { "name": "net.ipv4.tcp_syncookies", "value": "1", "flush": "net.ipv4.route.flush", "check": "tcp_syncookies" }
    ],
    "ipv6": [
      { "name": "net.ipv6.conf.all.accept_redirects", "value": "0", "flush": "net.ipv6.route.flush", "check": "icmp_redirects" },
      { "name": "net.ipv6.conf.default.accept_redirects", "value": "0", "flush": "net.ipv6.route.flush", "check": "icmp_redirects" },
      { "name": "net.ipv6.conf.all.accept_source_route", "value": "0", "flush": "net.ipv6.route.flush", "check": "source_route" },
      { "name": "net.ipv6.conf.default.accept_source_route", "value": "0", "flush": "net.ipv6.route.flush", "check": "source_route" },
      { "name": "net.ipv6.conf.all.accept_ra", "value": "0", "flush": "net.ipv6.route.flush", "check": "ipv6_router_advertisements" },
      { "name": "net.ipv6.conf.default.accept_ra", "value": "0", "flush": "net.ipv6.route.flush", "check": "ipv6_router_advertisements" }
    ]
  }
}