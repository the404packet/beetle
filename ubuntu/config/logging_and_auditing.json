{
  "journald": {
    "service": "systemd-journald",
    "config_file": "/etc/systemd/journald.conf",
    "config_drop_dir": "/etc/systemd/journald.conf.d",
    "tmpfiles_config": "/etc/tmpfiles.d/systemd.conf",
    "tmpfiles_source": "/usr/lib/tmpfiles.d/systemd.conf",
    "rotation_params": [
      {
        "key": "SystemMaxUse",
        "value": "1G"
      },
      {
        "key": "SystemKeepFree",
        "value": "500M"
      },
      {
        "key": "RuntimeMaxUse",
        "value": "200M"
      },
      {
        "key": "RuntimeKeepFree",
        "value": "50M"
      },
      {
        "key": "MaxFileSec",
        "value": "1month"
      }
    ]
  },
  "journal_remote": {
    "package": "systemd-journal-remote",
    "upload_svc": "systemd-journal-upload.service",
    "remote_svc": "systemd-journal-remote.service",
    "remote_sock": "systemd-journal-remote.socket",
    "upload_conf_dir": "/etc/systemd/journal-upload.conf.d",
    "upload_drop_file": "60-cis-upload.conf",
    "upload_auth": {
      "server_key": "/etc/ssl/private/journal-upload.pem",
      "server_cert": "/etc/ssl/certs/journal-upload.pem",
      "trusted_cert": "/etc/ssl/ca/trusted.pem"
    }
  },
  "journald_params": [
    {
      "key": "ForwardToSyslog",
      "value": "no"
    },
    {
      "key": "Compress",
      "value": "yes"
    },
    {
      "key": "Storage",
      "value": "persistent"
    }
  ],
  "rsyslog": {
  "package":          "rsyslog",
  "service":          "rsyslog.service",
  "config_file":      "/etc/rsyslog.conf",
  "config_dir":       "/etc/rsyslog.d",
  "drop_file":        "60-cis-rsyslog.conf",
  "file_create_mode": "0640",
  "remote_port":      "514",
  "remote_protocol":  "tcp",
  "queue_type":       "LinkedList",
  "queue_size":       "1000",
  "resume_retry":     "100",
  "logrotate_config": "/etc/logrotate.conf",
  "logrotate_dir":    "/etc/logrotate.d",
  "logging_rules": [
    { "name": "auth",     "rule": "auth,authpriv.*"                          , "dest": "/var/log/secure"        },
    { "name": "mail",     "rule": "mail.*"                                   , "dest": "-/var/log/mail"         },
    { "name": "cron",     "rule": "cron.*"                                   , "dest": "/var/log/cron"          },
    { "name": "warn",     "rule": "*.=warning;*.=err"                        , "dest": "-/var/log/warn"         },
    { "name": "crit",     "rule": "*.crit"                                   , "dest": "/var/log/warn"          },
    { "name": "messages", "rule": "*.*;mail.none;news.none"                  , "dest": "-/var/log/messages"     },
    { "name": "emerg",    "rule": "*.emerg"                                  , "dest": ":omusrmsg:*"            },
    { "name": "local",    "rule": "local0,local1,local2,local3,local4,local5,local6,local7.*", "dest": "-/var/log/localmessages" }
  ]
}
}