{
  "journald": {
    "service": "systemd-journald",
    "config_file": "/etc/systemd/journald.conf",
    "config_drop_dir": "/etc/systemd/journald.conf.d",
    "tmpfiles_config": "/etc/tmpfiles.d/systemd.conf",
    "tmpfiles_source": "/usr/lib/tmpfiles.d/systemd.conf",
    "rotation_params": [
      {
        "key": "SystemMaxUse",
        "value": "1G"
      },
      {
        "key": "SystemKeepFree",
        "value": "500M"
      },
      {
        "key": "RuntimeMaxUse",
        "value": "200M"
      },
      {
        "key": "RuntimeKeepFree",
        "value": "50M"
      },
      {
        "key": "MaxFileSec",
        "value": "1month"
      }
    ]
  },
  "journal_remote": {
    "package": "systemd-journal-remote",
    "upload_svc": "systemd-journal-upload.service",
    "remote_svc": "systemd-journal-remote.service",
    "remote_sock": "systemd-journal-remote.socket",
    "upload_conf_dir": "/etc/systemd/journal-upload.conf.d",
    "upload_drop_file": "60-cis-upload.conf",
    "upload_auth": {
      "server_key": "/etc/ssl/private/journal-upload.pem",
      "server_cert": "/etc/ssl/certs/journal-upload.pem",
      "trusted_cert": "/etc/ssl/ca/trusted.pem"
    }
  },
  "journald_params": [
    {
      "key": "ForwardToSyslog",
      "value": "no"
    },
    {
      "key": "Compress",
      "value": "yes"
    },
    {
      "key": "Storage",
      "value": "persistent"
    }
  ],
  "rsyslog": {
    "package": "rsyslog",
    "service": "rsyslog.service",
    "config_file": "/etc/rsyslog.conf",
    "config_dir": "/etc/rsyslog.d",
    "drop_file": "60-cis-rsyslog.conf",
    "file_create_mode": "0640",
    "remote_port": "514",
    "remote_protocol": "tcp",
    "queue_type": "LinkedList",
    "queue_size": "1000",
    "resume_retry": "100",
    "logrotate_config": "/etc/logrotate.conf",
    "logrotate_dir": "/etc/logrotate.d",
    "logging_rules": [
      {
        "name": "auth",
        "rule": "auth,authpriv.*",
        "dest": "/var/log/secure"
      },
      {
        "name": "mail",
        "rule": "mail.*",
        "dest": "-/var/log/mail"
      },
      {
        "name": "cron",
        "rule": "cron.*",
        "dest": "/var/log/cron"
      },
      {
        "name": "warn",
        "rule": "*.=warning;*.=err",
        "dest": "-/var/log/warn"
      },
      {
        "name": "crit",
        "rule": "*.crit",
        "dest": "/var/log/warn"
      },
      {
        "name": "messages",
        "rule": "*.*;mail.none;news.none",
        "dest": "-/var/log/messages"
      },
      {
        "name": "emerg",
        "rule": "*.emerg",
        "dest": ":omusrmsg:*"
      },
      {
        "name": "local",
        "rule": "local0,local1,local2,local3,local4,local5,local6,local7.*",
        "dest": "-/var/log/localmessages"
      }
    ]
  },
  "logfile_permissions": {
    "search_dir": "/var/log",
    "rules": [
      {
        "match_type": "dir_pattern",
        "pattern": "/(apt)$",
        "perm_mask": "0133",
        "rperms": "u-x,go-wx",
        "owner": "root",
        "group": "(root|adm)",
        "fix_group": "adm"
      },
      {
        "match_type": "basename",
        "pattern": "lastlog|lastlog.*|wtmp|wtmp.*|wtmp-*|btmp|btmp.*|btmp-*|README",
        "perm_mask": "0113",
        "rperms": "ug-x,o-wx",
        "owner": "root",
        "group": "(root|utmp)",
        "fix_group": "utmp"
      },
      {
        "match_type": "basename",
        "pattern": "cloud-init.log.*|localmessages.*|waagent.log.*",
        "perm_mask": "0133",
        "rperms": "u-x,go-wx",
        "owner": "(root|syslog)",
        "group": "(root|adm)",
        "fix_group": "adm"
      },
      {
        "match_type": "basename",
        "pattern": "secure|auth.log|syslog|messages",
        "perm_mask": "0137",
        "rperms": "u-x,g-wx,o-rwx",
        "owner": "(root|syslog)",
        "group": "(root|adm)",
        "fix_group": "adm"
      },
      {
        "match_type": "basename",
        "pattern": "SSSD|sssd",
        "perm_mask": "0117",
        "rperms": "ug-x,o-rwx",
        "owner": "(root|SSSD)",
        "group": "(root|SSSD)",
        "fix_group": "SSSD"
      },
      {
        "match_type": "basename",
        "pattern": "gdm|gdm3",
        "perm_mask": "0117",
        "rperms": "ug-x,o-rwx",
        "owner": "root",
        "group": "(root|gdm|gdm3)",
        "fix_group": "gdm"
      },
      {
        "match_type": "basename",
        "pattern": ".*\\.journal|.*\\.journal~",
        "perm_mask": "0137",
        "rperms": "u-x,g-wx,o-rwx",
        "owner": "root",
        "group": "(root|systemd-journal)",
        "fix_group": "systemd-journal"
      },
      {
        "match_type": "default",
        "pattern": ".*",
        "perm_mask": "0137",
        "rperms": "u-x,g-wx,o-rwx",
        "owner": "(root|syslog)",
        "group": "(root|adm)",
        "fix_group": "adm"
      }
    ]
  },
  "auditd": {
  "packages": [
    { "name": "auditd"          },
    { "name": "audispd-plugins" }
  ],
  "service":        "auditd",
  "grub_config":    "/etc/default/grub",
  "grub_cmdline_key": "GRUB_CMDLINE_LINUX",
  "grub_params": [
    { "name": "audit",               "value": "1"    },
    { "name": "audit_backlog_limit", "value": "8192" }
  ]
},
"auditd_config": {
  "config_file": "/etc/audit/auditd.conf",
  "params": [
    { "name": "max_log_file",          "value": "8",         "valid_values": ""                    },
    { "name": "max_log_file_action",   "value": "keep_logs", "valid_values": "keep_logs"           },
    { "name": "disk_full_action",      "value": "halt",      "valid_values": "halt|single"         },
    { "name": "disk_error_action",     "value": "halt",      "valid_values": "syslog|single|halt"  },
    { "name": "space_left_action",     "value": "email",     "valid_values": "email|exec|single|halt" },
    { "name": "admin_space_left_action", "value": "single",  "valid_values": "single|halt"         }
  ]
},
"audit_rules": {
  "rules_dir": "/etc/audit/rules.d",
  "rule_groups": [
    {
      "name": "scope",
      "file": "50-scope.rules",
      "key":  "scope",
      "rules": [
        "-w /etc/sudoers -p wa -k scope",
        "-w /etc/sudoers.d -p wa -k scope"
      ]
    },
    {
      "name": "user_emulation",
      "file": "50-user_emulation.rules",
      "key":  "user_emulation",
      "rules": [
        "-a always,exit -F arch=b64 -C euid!=uid -F auid!=unset -S execve -k user_emulation",
        "-a always,exit -F arch=b32 -C euid!=uid -F auid!=unset -S execve -k user_emulation"
      ]
    },
    {
      "name": "sudo_log_file",
      "file": "50-sudo.rules",
      "key":  "sudo_log_file",
      "rules": []
    },
    {
      "name": "time_change",
      "file": "50-time-change.rules",
      "key":  "time-change",
      "rules": [
        "-a always,exit -F arch=b64 -S adjtimex,settimeofday -k time-change",
        "-a always,exit -F arch=b32 -S adjtimex,settimeofday -k time-change",
        "-a always,exit -F arch=b64 -S clock_settime -F a0=0x0 -k time-change",
        "-a always,exit -F arch=b32 -S clock_settime -F a0=0x0 -k time-change",
        "-w /etc/localtime -p wa -k time-change"
      ]
    },
    {
      "name": "system_locale",
      "file": "50-system_locale.rules",
      "key":  "system-locale",
      "rules": [
        "-a always,exit -F arch=b64 -S sethostname,setdomainname -k system-locale",
        "-a always,exit -F arch=b32 -S sethostname,setdomainname -k system-locale",
        "-w /etc/issue -p wa -k system-locale",
        "-w /etc/issue.net -p wa -k system-locale",
        "-w /etc/hosts -p wa -k system-locale",
        "-w /etc/networks -p wa -k system-locale",
        "-w /etc/network -p wa -k system-locale",
        "-w /etc/netplan -p wa -k system-locale"
      ]
    },
    {
      "name": "privileged",
      "file": "50-privileged.rules",
      "key":  "privileged",
      "rules": []
    },
    {
  "name": "access",
  "file": "50-access.rules",
  "key":  "access",
  "rules": [],
  "uid_min_dynamic": true
},
{
  "name": "identity",
  "file": "50-identity.rules",
  "key":  "identity",
  "rules": [
    "-w /etc/group -p wa -k identity",
    "-w /etc/passwd -p wa -k identity",
    "-w /etc/gshadow -p wa -k identity",
    "-w /etc/shadow -p wa -k identity",
    "-w /etc/security/opasswd -p wa -k identity",
    "-w /etc/nsswitch.conf -p wa -k identity",
    "-w /etc/pam.conf -p wa -k identity",
    "-w /etc/pam.d -p wa -k identity"
  ]
},
{
  "name": "perm_mod",
  "file": "50-perm_mod.rules",
  "key":  "perm_mod",
  "rules": [],
  "uid_min_dynamic": true
},
{
  "name": "mounts",
  "file": "50-mounts.rules",
  "key":  "mounts",
  "rules": [],
  "uid_min_dynamic": true
},
{
  "name": "session",
  "file": "50-session.rules",
  "key":  "session",
  "rules": [
    "-w /var/run/utmp -p wa -k session",
    "-w /var/log/wtmp -p wa -k session",
    "-w /var/log/btmp -p wa -k session"
  ]
},
{
  "name": "logins",
  "file": "50-login.rules",
  "key":  "logins",
  "rules": [
    "-w /var/log/lastlog -p wa -k logins",
    "-w /var/run/faillock -p wa -k logins"
  ]
},
{
  "name": "delete",
  "file": "50-delete.rules",
  "key":  "delete",
  "rules": [],
  "uid_min_dynamic": true
},
{
  "name": "MAC_policy",
  "file": "50-MAC-policy.rules",
  "key":  "MAC-policy",
  "rules": [
    "-w /etc/apparmor/ -p wa -k MAC-policy",
    "-w /etc/apparmor.d/ -p wa -k MAC-policy"
  ]
}
  ]
}
}