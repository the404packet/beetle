{
  "firewall": {
    "active_tool": "ufw",
    "allowed_tools": ["ufw", "nftables", "iptables"]
  },
  "ufw": {
    "required_packages": [
      { "name": "ufw" }
    ],
    "banned_with_ufw": [
      { "name": "iptables-persistent" }
    ],
    "loopback": {
      "allow_in": "lo",
      "allow_out": "lo",
      "deny_in": "127.0.0.0/8",
      "deny_in6": "::1"
    },
    "default_policies": {
      "incoming": "deny",
      "outgoing": "allow",
      "routed": "disabled"
    }
  },
  "nftables": {
    "required_packages": [
      { "name": "nftables" }
    ],
    "banned_with_nftables": [
      { "name": "ufw" }
    ],
    "table": {
      "name": "filter",
      "family": "inet"
    },
    "base_chains": [
      { "name": "input",   "hook": "input",   "policy": "drop" },
      { "name": "forward", "hook": "forward", "policy": "drop" },
      { "name": "output",  "hook": "output",  "policy": "accept" }
    ],
    "loopback": {
      "iface": "lo",
      "deny_in": "127.0.0.0/8",
      "deny_in6": "::1"
    },
    "rules_file": "/etc/nftables.conf"
  },
  "iptables": {
    "required_packages": [
      { "name": "iptables" },
      { "name": "iptables-persistent" }
    ],
    "banned_with_iptables": [
      { "name": "ufw" }
    ],
    "loopback": {
      "iface": "lo",
      "deny_in": "127.0.0.0/8",
      "deny_in6": "::1"
    },
    "default_policies": {
      "input":   "DROP",
      "forward": "DROP",
      "output":  "ACCEPT"
    },
    "established_states": ["ESTABLISHED", "RELATED"],
    "rules_file": "/etc/iptables/rules.v4",
    "rules_file_v6": "/etc/iptables/rules.v6"
  }
}