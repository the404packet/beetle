#!/usr/bin/env bash

set -euo pipefail

BASE_DIR="/usr/local/bin/beetle_shell"

read -r line

read -ra parts <<< "$line"

command="${parts[0]:-}"

if [[ -z "$command" ]]; then
    echo "Invalid command"
    exit 1
fi

# security check
if [[ ! "$command" =~ ^[a-zA-Z0-9_-]+$ ]]; then
    echo "Invalid command"
    exit 1
fi

script="$BASE_DIR/${command}.sh"

if [[ -x "$script" ]]; then
    exec "$script" "${parts[@]:1}"
else
    echo "Unknown command"
fi