#!/usr/bin/env bash

set -euo pipefail

BASE_DIR="/usr/local/bin/beetle_shell"

read -r line

command=$(echo "$line" | awk '{print $1}')
args=$(echo "$line" | cut -d' ' -f2-)

if [[ ! "$command" =~ ^[a-zA-Z0-9_-]+$ ]]; then
    echo "Invalid command"
    exit 1
fi

script="$BASE_DIR/${command}.sh"

if [[ -x "$script" ]]; then
    exec "$script" $args
else
    echo "Unknown command"
fi