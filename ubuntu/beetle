#!/bin/bash

command="$1"
shift || true

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
COMMAND_FILE="$SCRIPT_DIR/beetle_shell/${command}.sh"

# If no command provided
if [ -z "$command" ]; then
    echo "Usage: beetle <command>"
    exit 1
fi

# Check if command exists and is executable
if [ -x "$COMMAND_FILE" ]; then
    "$COMMAND_FILE" "$@"
else
    echo "Unknown command: $command" >&2
    echo "Type 'beetle help' to see available commands."
    exit 1
fi
