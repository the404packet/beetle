#!/bin/bash

set -euo pipefail

command="${1:-}"
shift || true

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# ---------- Local Commands ----------
if [[ "$command" == "version" || "$command" == "banner" || "$command" == "help" ]]; then
    COMMAND_FILE="$SCRIPT_DIR/beetle_shell/${command}.sh"

    if [[ -x "$COMMAND_FILE" ]]; then
        exec "$COMMAND_FILE" "$@"
    else
        echo "Unknown command: $command"
        exit 1
    fi
fi

# ---------- Daemon Commands ----------
SOCKET="/var/run/beetle.sock"

if [[ ! -S "$SOCKET" ]]; then
    echo "Beetle daemon not running"
    exit 1
fi

# Send full command safely via socat
printf '%s\n' "$command $*" | beetled - UNIX-CONNECT:"$SOCKET"