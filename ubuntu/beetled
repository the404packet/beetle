#!/usr/bin/env python3
import socket
import os
import subprocess
import grp

SOCKET_PATH = "/var/run/beetle.sock"
BASE_DIR = "/usr/local/bin/beetle_shell"

# Cleanup old socket
if os.path.exists(SOCKET_PATH):
    os.remove(SOCKET_PATH)

server = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
server.bind(SOCKET_PATH)

# Set permissions root:beetle 660
gid = grp.getgrnam("beetle").gr_gid
os.chown(SOCKET_PATH, 0, gid)
os.chmod(SOCKET_PATH, 0o660)

server.listen(5)

print("Beetle daemon running...")

while True:
    conn, _ = server.accept()

    data = conn.recv(4096).decode().strip()
    if not data:
        conn.close()
        continue

    parts = data.split()
    command = parts[0]
    args = parts[1:]

    # SECURITY: only allow alphanumeric commands
    if not command.isalnum():
        conn.send(b"Invalid command\n")
        conn.close()
        continue

    script_path = os.path.join(BASE_DIR, f"{command}.sh")

    if os.path.isfile(script_path) and os.access(script_path, os.X_OK):
        process = subprocess.Popen(
            [script_path] + args,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True
        )

        # Stream output live
        for line in process.stdout:
            conn.send(line.encode())

        process.wait()
    else:
        conn.send(b"Unknown command\n")

    conn.close()