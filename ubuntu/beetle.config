# =========================
# Beetle Configuration File
# =========================

# -------- Core --------
BEETLE_MODE=audit
BEETLE_SHELL_ROOT=/usr/local/bin/beetle_shell

# -------- Audit Discovery --------
# Treat ONLY immediate subdirectories of beetle_shell as categories
AUDIT_CATEGORY_ROOT=${BEETLE_SHELL_ROOT}

# Recursively scan inside each category
AUDIT_RECURSIVE=true

# Only execute shell scripts
AUDIT_SCRIPT_PATTERN=*.sh

# Ignore scripts directly inside beetle_shell
AUDIT_IGNORE_ROOT_FILES=true

# -------- Execution --------
AUDIT_SHELL="/usr/bin/env bash"

# If a script produces NO output for N seconds → skip it
AUDIT_OUTPUT_TIMEOUT=5

# Do NOT kill long-running scripts if they produce output
AUDIT_EXECUTION_TIMEOUT=10

# Continue even if one script fails or hangs
# AUDIT_CONTINUE_ON_ERROR=true

# Prevent fork bombs (WSL-safe)
AUDIT_MAX_CONCURRENT=1

# Run scripts in deterministic order
AUDIT_SORT=true

# -------- Logging --------
AUDIT_LOG_ENABLED=true
AUDIT_LOG_DIR=/var/log/beetle
AUDIT_LOG_LEVEL=info
