{
  "ssh_config_file_permissions": {
    "sshd_config": {
      "file": "/etc/ssh/sshd_config",
      "perm_mask": "0177",
      "owner": "root",
      "group": "root"
    },
    "private_host_key": {
      "perm_mask": "0177",
      "owner": "root",
      "group": "root"
    },
    "public_host_key": {
      "perm_mask": "0133",
      "owner": "root",
      "group": "root"
    }
  },
  "sshd_settings": {
    "loglevel": {
      "allowed": ["INFO", "VERBOSE"]
    },
    "logingracetime": {
      "min": 1,
      "max": 60
    },
    "maxauthtries": {
      "max": 4
    },
    "maxsessions": {
      "max": 10
    },
    "maxstartups": {
      "start_max": 10,
      "rate_max": 30,
      "full_max": 60,
      "value": "10:30:60"
    },
    "clientaliveinterval": {
      "min": 1
    },
    "clientalivecountmax": {
      "min": 1
    },
    "permitrootlogin": {
      "expected": "no"
    },
    "permitemptypasswords": {
      "expected": "no"
    },
    "permituserenvironment": {
      "expected": "no"
    },
    "gssapiauthentication": {
      "expected": "no"
    },
    "hostbasedauthentication": {
      "expected": "no"
    },
    "ignorerhosts": {
      "expected": "yes"
    },
    "disableforwarding": {
      "expected": "yes"
    },
    "usepam": {
      "expected": "yes"
    }
  },
  "sshd_weak_ciphers": [
    "3des-cbc",
    "blowfish-cbc",
    "cast128-cbc",
    "aes128-cbc",
    "aes192-cbc",
    "aes256-cbc",
    "arcfour",
    "arcfour128",
    "arcfour256",
    "rijndael-cbc@lysator.liu.se"
  ],
  "sshd_weak_macs": [
    "hmac-md5",
    "hmac-md5-96",
    "hmac-ripemd160",
    "hmac-sha1-96",
    "umac-64@openssh.com",
    "hmac-md5-etm@openssh.com",
    "hmac-md5-96-etm@openssh.com",
    "hmac-ripemd160-etm@openssh.com",
    "hmac-sha1-96-etm@openssh.com",
    "umac-64-etm@openssh.com",
    "umac-128-etm@openssh.com"
  ],
  "sshd_weak_kex": [
    "diffie-hellman-group1-sha1",
    "diffie-hellman-group14-sha1",
    "diffie-hellman-group-exchange-sha1"
  ],
  "sudo_settings": {
      "timestamp_timeout": {
          "max": 15
      },
      "logfile": {
          "path": "/var/log/sudo.log"
      },
      "su_restrict_group": {
          "name": "sugroup"
      }
  },
  "pam_settings": {
    "libpam_runtime": {
      "min_version": "1.5.3-5"
    },
    "libpam_modules": {
      "min_version": "1.5.3-5"
    },
    "faillock": {
      "deny_max": 5,
      "unlock_time_min": 900,
      "unlock_time_value": 900,
      "root_unlock_time_min": 60,
      "root_unlock_time_value": 60
    },
    "pwquality": {
      "difok_min": 2,
      "minlen_min": 14,
      "minclass": 3,
      "maxrepeat_max": 3,
      "maxsequence_max": 3
    },
    "pwhistory": {
      "remember_min": 24
    },
    "unix": {
      "hash_algo": "yescrypt"
    }
  },
    "login_defs": {
    "file": "/etc/login.defs",
    "pass_max_days": {
      "max": 365
    },
    "pass_min_days": {
      "min": 1
    },
    "pass_warn_age": {
      "min": 7
    },
    "encrypt_method": {
      "allowed": ["SHA512", "YESCRYPT"]
    },
    "inactive": {
      "max": 45
    }
  },

  "user_env": {
    "tmout": {
      "max": 900,
      "profile_d_file": "/etc/profile.d/50-systemwide_tmout.sh"
    },
    "umask": {
      "value": "027",
      "profile_d_file": "/etc/profile.d/50-systemwide_umask.sh"
    },
    "root_umask": {
      "files": ["/root/.bash_profile", "/root/.bashrc"]
    }
  }
}

